   "outputs": [],
   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "1e956050-b723-4719-944d-26fa07befa06",
   "metadata": {},
   "outputs": [],
   "source": [
    "X=np.array([[1,1],[1,-1],[-1,1],[-1,-1]])\n",
    "y=np.array([1,-1,-1,-1])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "d8417500-4a82-4fe6-a06a-f56bcdba2a72",
   "metadata": {},
   "outputs": [],
   "source": [
    "w=np.zeros(2)\n",
    "b=0\n",
    "lr=0.01"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "d6f0023f-ed05-4e50-9f1e-9286d009ff6b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[0.16758368 0.16758368] -0.16758368200424947\n"
     ]
    }
   ],
   "source": [
    "for epoch in range(10):\n",
    "  y_pred=np.dot(X,w)+b\n",
    "  error=y-y_pred\n",
    "  w+=lr*np.dot(X.T,error)\n",
    "  b+=lr*error.sum()\n",
    "print(w,b)"
   ]
  },
